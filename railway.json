{
  "build": {
    "builder": "nixpacks",
    "watch": ["backend/**"],
    "buildCommand": "cd backend && npm install && npm run build",
    "nixpacksConfig": {
      "providers": ["node"],
      "installCommand": "cd backend && npm install"
    }
  },
  "deploy": {
    "startCommand": "cd backend && npm start",
    "healthcheckPath": "/health"
  }
}